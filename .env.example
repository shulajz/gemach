# Dedicated Google API key for Drive folder import in the gallery admin.
# Create in Google Cloud Console → APIs & Services → Credentials → Create API key
# Restrict the key to "Google Drive API" and add your site under HTTP referrers.
VITE_GOOGLE_DRIVE_API_KEY=

# Comma-separated admin emails allowed to permanently delete archived orders.
# Example: you@gmail.com,friend@gmail.com
VITE_ARCHIVE_DELETE_EMAILS=
