rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isValidDateKey(date) {
      return date.matches('^\\d{4}-\\d{2}-\\d{2}$');
    }

    function isValidReservationDoc() {
      return request.resource.data.keys().hasOnly(['itemReservations', 'updatedAt'])
        && request.resource.data.itemReservations is map;
    }

    // Public: read items and reservations (for availability)
    match /items/{itemId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /reservations/{date} {
      allow read: if true;
      // Admins always; public may update daily reservation counts when placing/editing orders
      allow create, update: if request.auth != null
        || (isValidDateKey(date) && isValidReservationDoc());
      allow delete: if request.auth != null;
    }
    // Public: create orders only; admin can read/update
    match /orders/{orderId} {
      allow create: if true;
      allow read, update: if true;
      allow delete: if request.auth != null;
    }
    // Admin settings (e.g. opening schedule)
    match /settings/{docId} {
      allow read: if request.auth != null || docId == "importantInfo" || docId == "openingSchedule";
      allow write: if request.auth != null;
    }
    // Public gallery: anyone can view, admin can manage
    match /gallery/{imageId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
